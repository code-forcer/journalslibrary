  <!-- count js -->
  <script>
    document.addEventListener('DOMContentLoaded', async () => {
      const userCountElement = document.getElementById('userCount');

      try {
        const response = await fetch('/counter'); // Adjust API path as necessary
        if (!response.ok) throw new Error('Failed to fetch user count');

        const data = await response.json();
        userCountElement.textContent = data.count;
      } catch (error) {
        console.error('Error fetching user count:', error);
        userCountElement.textContent = 'Error';
      }
    });
    document.addEventListener('DOMContentLoaded', async () => {
      const userCountElement = document.getElementById('subCount');

      try {
        const response = await fetch('/totalsubmission'); // Adjust API path as necessary
        if (!response.ok) throw new Error('Failed to fetch user count');

        const data = await response.json();
        userCountElement.textContent = data.count;
      } catch (error) {
        console.error('Error fetching user count:', error);
        userCountElement.textContent = 'Error';
      }
    });
    document.addEventListener('DOMContentLoaded', async () => {
      const userCountElement = document.getElementById('contactCount');

      try {
        const response = await fetch('/totalcontacts'); // Adjust API path as necessary
        if (!response.ok) throw new Error('Failed to fetch user count');

        const data = await response.json();
        userCountElement.textContent = data.count;
      } catch (error) {
        console.error('Error fetching user count:', error);
        userCountElement.textContent = 'Error';
      }
    });
  </script>
